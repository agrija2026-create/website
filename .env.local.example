# 本番URL（OG・canonical・JSON-LD 用。未設定時は https://agri-ja.net）
# NEXT_PUBLIC_SITE_URL=https://agri-ja.net

# 記事データ取得元の切り替え
# local | microcms | auto
ARTICLE_DATA_SOURCE=local

# microCMS が失敗したときに local に自動で戻すか
ARTICLE_FALLBACK_TO_LOCAL=true

# microCMS を使うときに設定
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=
MICROCMS_ENDPOINT=articles
